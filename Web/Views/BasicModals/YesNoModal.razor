@inherits YesNoModalBase

<MudDialog>
    <DialogContent>
        @Text
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => SendResult(false)" Color="Color.Secondary" Variant="Variant.Filled">@FalseButtonText</MudButton>
        <MudButton OnClick="() => SendResult(true)" Color="Color.Primary" Variant="Variant.Filled">@TrueButtonText</MudButton>
    </DialogActions>
</MudDialog>